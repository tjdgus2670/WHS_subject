SECRET_KEY=change-this-to-a-long-random-value
# DATABASE_URL은 기본적으로 비워둔다. config.py가 프로젝트 위치를 기준으로
# 절대경로(sqlite:///.../instance/app.db)를 실행 시점에 자동 계산해서 쓰기 때문에
# 이 값이 없어도 항상 정확하게 동작한다(어느 컴퓨터/폴더에서 실행하든 문제 없음).
# 여기에 상대경로(sqlite:///instance/app.db)를 직접 넣으면 Windows에서
# "unable to open database file" 오류가 날 수 있으니 넣지 않는다.
# sqlite가 아닌 다른 DB(운영 환경의 Postgres 등)를 쓸 때만 이 줄의 주석을 풀고 채운다.
# DATABASE_URL=
SESSION_COOKIE_SECURE=False
FLASK_ENV=development
